# Lumin India Engine — environment template.
# Copy to .env and fill in values. Never commit the real .env.
# All secrets are injected by the GitHub Actions deploy workflow.

# --- Fyers API (data feed) ---
# App credentials from myapi.fyers.in. Access token is obtained via
# OAuth2 daily refresh (Phase 2: signing service handles this).
FYERS_CLIENT_ID=
FYERS_ACCESS_TOKEN=

# --- Engine mode ---
INDIA_DEV_MODE=false
AUTO_EXECUTION_ENABLED=false
INDEX_FUTURES_ONLY=true
ALLOWED_BASES=NIFTY,BANKNIFTY

# --- Scanner ---
INDIA_SCAN_INTERVAL=30

# --- API ---
API_PORT=8000
API_STATIC_TOKEN=
