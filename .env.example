# Lumin India Engine — environment template.
# Copy to .env and fill in values. Never commit the real .env.
# All secrets are injected by the GitHub Actions deploy workflow.

# --- Fyers API (data feed) ---
# App credentials from myapi.fyers.in.
# One interactive login (~every 15 days): scripts/fyers_token.py writes
# FYERS_ACCESS_TOKEN + FYERS_REFRESH_TOKEN. In between, the 08:45 IST cron
# (scripts/fyers_refresh.py, installed by the deploy workflow) refreshes the
# daily access token automatically using SECRET_KEY + PIN + REFRESH_TOKEN.
FYERS_CLIENT_ID=
FYERS_ACCESS_TOKEN=
FYERS_SECRET_KEY=
FYERS_PIN=
FYERS_REFRESH_TOKEN=

# --- Data feed selection ---
# fyers (default): one-tap daily login via https://lumintrade.app/fyers/callback
# angel: zero-touch — engine re-logs in itself each morning via official TOTP
DATA_FEED=fyers

# --- Angel One SmartAPI (DATA_FEED=angel) ---
# Free account + API key from smartapi.angelbroking.com. TOTP secret is the
# base32 string shown when enabling TOTP at smartapi.angelbroking.com/enable-totp.
ANGEL_API_KEY=
ANGEL_CLIENT_CODE=
ANGEL_PIN=
ANGEL_TOTP_SECRET=

# --- Engine mode ---
INDIA_DEV_MODE=false
AUTO_EXECUTION_ENABLED=false
INDEX_FUTURES_ONLY=true
ALLOWED_BASES=NIFTY,BANKNIFTY

# --- Scanner ---
INDIA_SCAN_INTERVAL=30

# --- API ---
API_PORT=8000
API_STATIC_TOKEN=
